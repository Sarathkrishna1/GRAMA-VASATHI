<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Property Name -->
        <TextView
            android:id="@+id/tvBookProp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Farm Name"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1B5E20" />

        <!-- Guest Name and Phone -->
        <TextView
            android:id="@+id/tvBookGuest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Guest: Sarath (9876543210)"
            android:textColor="#616161"
            android:layout_marginTop="4dp" />

        <!-- Booking Date -->
        <TextView
            android:id="@+id/tvBookDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date: 15/05/2024"
            android:textColor="#1976D2"
            android:layout_marginTop="4dp" />

        <!-- Current Status -->
        <TextView
            android:id="@+id/tvBookStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Pending"
            android:textStyle="italic"
            android:layout_marginTop="8dp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnAccept"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ACCEPT"
                android:backgroundTint="#4CAF50"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnReject"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="REJECT"
                android:backgroundTint="#F44336" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>