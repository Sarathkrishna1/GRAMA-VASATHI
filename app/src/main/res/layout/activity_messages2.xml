<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FDFCFB"
    android:padding="20dp">

    <!-- Header: Using Built-in Serif for that high-end look -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Guest Inquiries"
        android:textSize="32sp"
        android:fontFamily="serif"
        android:textStyle="bold"
        android:textColor="#1B5E20"
        android:layout_marginBottom="24dp" />

    <!-- Dummy Message Card 1 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#FFFFFF">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sarath - Malnad Stay"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Is dinner included in the booking price?"
                android:textColor="#666666"
                android:fontFamily="sans-serif-light" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Dummy Message Card 2 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#FFFFFF">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rahul - Coorg Estate"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Can we bring our pet dog with us?"
                android:textColor="#666666"
                android:fontFamily="sans-serif-light" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>